<?xml version="1.0" encoding="UTF-8"?>
<!--
   Vendored excerpt of the real pom.xml published to Maven Central:
   https://repo1.maven.org/maven2/org/apache/commons/commons-lang3/3.14.0/commons-lang3-3.14.0.pom

